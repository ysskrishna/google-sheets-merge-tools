---
import BaseLayout from '../layouts/BaseLayout.astro';

const site = 'https://ysskrishna.github.io/google-sheets-merge-tools';
const pageUrl = `${site}/support.html`;

const ldJson = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${site}/#website`,
      name: 'Merge Tools',
      url: `${site}/`,
    },
    {
      '@type': 'ContactPage',
      '@id': `${pageUrl}#webpage`,
      name: 'Support — Merge Tools',
      description:
        'Get help with Merge Tools: support contact details, issue reporting guidelines, and response expectations.',
      url: pageUrl,
      isPartOf: { '@id': `${site}/#website` },
      inLanguage: 'en',
    },
  ],
};
---

<BaseLayout
  title="Support — Merge Tools"
  description="Get help with Merge Tools: support contact details, issue reporting guidelines, and response expectations."
  canonical={pageUrl}
  navKey="support"
  mainClass="site-main--inner"
  ogTitle="Support — Merge Tools"
  ogDescription="Support channels and issue-reporting guidance for Merge Tools."
  ogUrl={pageUrl}
  twitterCard="summary"
  ldJson={ldJson}
>
  <h1 class="page-title">Support</h1>
  <p class="page-intro">Need help with Merge Tools? Use one of the options below.</p>

  <div class="contact-card">
    <h2>Contact</h2>
    <ul>
      <li>Email: <a href="mailto:sivasaikrishnassk@gmail.com">sivasaikrishnassk@gmail.com</a></li>
      <li>
        GitHub Issues:
        <a href="https://github.com/ysskrishna/google-sheets-merge-tools/issues">
          https://github.com/ysskrishna/google-sheets-merge-tools/issues
        </a>
      </li>
    </ul>
  </div>

  <h2>Response Time</h2>
  <p>
    Support is provided on a best-effort basis. Typical response time is 3 to 5 business days, but faster or slower
    responses can happen based on complexity and availability.
  </p>

  <h2>When reporting an issue</h2>
  <ul>
    <li>Share clear steps to reproduce the issue.</li>
    <li>Include what you expected versus what happened.</li>
    <li>Add screenshots or exact error messages when possible.</li>
    <li>Avoid posting sensitive spreadsheet data in public issues.</li>
  </ul>

  <h2>No Affiliation</h2>
  <p>This add-on is an independent project and is not affiliated with, endorsed by, or sponsored by Google LLC.</p>
</BaseLayout>
